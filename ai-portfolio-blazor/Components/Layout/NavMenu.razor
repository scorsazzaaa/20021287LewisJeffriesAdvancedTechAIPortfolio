@using Blazorise

<BarBrand Margin="Margin.Is4.FromStart.Is4.FromTop">
    <div class="d-flex align-items-center">
        <span style="font-size: 2rem; margin-right: 0.75rem;">✦</span>
        <div>
            <Heading Size="HeadingSize.Is6" Margin="Margin.Is0" TextColor="TextColor.White">AI Portfolio</Heading>
            <Paragraph TextColor="TextColor.Muted" Margin="Margin.Is0" Style="font-size: 0.75rem;">Generator</Paragraph>
        </div>
    </div>
</BarBrand>

<BarMenu>
    <BarStart>
        <BarItem>
            <BarLink To="/" TextColor="TextColor.White">
                <Icon Name="IconName.Home" Margin="Margin.Is3.FromEnd" /> Generator
            </BarLink>
        </BarItem>
        <BarItem>
            <BarLink To="/about" TextColor="TextColor.Muted">
                <Icon Name="IconName.InfoCircle" Margin="Margin.Is3.FromEnd" /> About
            </BarLink>
        </BarItem>
    </BarStart>
</BarMenu>
